{
  "version": "0.2.0",
  "configurations": [

    {
      "type": "node",
      "request": "launch",
      "name": "Debug Backend",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/server/server.ts", // Path to your entry file
      "restart": true,
      "runtimeExecutable": "", // Optional: if you use nodemon
      "console": "integratedTerminal"
    },

    {
  "type": "chrome",
  "request": "launch",
  "name": "Debug Frontend",
  "url": "http://localhost:5173", // The URL where your React app runs
  "webRoot": "${workspaceFolder}/client/src"
}

  ]
}
